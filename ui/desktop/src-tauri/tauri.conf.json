{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foti",
  "version": "0.1.0",
  "identifier": "technology.wieland.foti",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Foti",
        "width": 1280,
        "height": 860,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "category": "Photography",
    "shortDescription": "Local AI photo management",
    "longDescription": "Foti is a local, private, AI-powered photo manager for Linux: content and text search, faces and people, duplicates, colour search, aesthetic ranking, and XMP export — all on your own machine. This desktop app launches and connects to a local Foti backend.",
    "homepage": "https://github.com/wtelias/foti",
    "license": "AGPL-3.0-or-later",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
