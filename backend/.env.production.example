# Foti backend — production env vars. Copy to .env.production and fill in.
# DO NOT commit .env.production (gitignored).

# HTTP Basic auth (delete both lines to disable auth — only safe behind a
# tailnet, never on a public Funnel).
FOTI_BASIC_USER=you
FOTI_BASIC_PASS=__set_a_long_random_password__

# Storage / runtime (defaults to ~/.local/share/foti if unset)
# FOTI_DATA_DIR=/var/lib/foti
FOTI_HOST=127.0.0.1
FOTI_PORT=7777

# CLIP
FOTI_CLIP_MODEL=ViT-L-14
FOTI_CLIP_PRETRAINED=openai
FOTI_CLIP_DEVICE=auto
FOTI_CLIP_BATCH_SIZE=32
